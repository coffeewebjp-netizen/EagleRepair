<Window x:Class="CoffeeDiagnose.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CoffeeDiagnose — トラブル修復ツール"
        Width="1120" Height="780" MinWidth="880" MinHeight="650"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource PageBrush}"
        FontFamily="Yu Gothic UI"
        Closing="Window_Closing">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#141B2D" Padding="34,26">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal">
                    <Border Background="#5965E8" CornerRadius="10" Width="44" Height="44" Margin="0,0,14,0">
                        <TextBlock Text="C" Foreground="White" FontSize="22" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="CoffeeDiagnose" Foreground="White" FontSize="25" FontWeight="Bold" />
                        <TextBlock Text="アプリやデバイスの不具合を診断し、安全な手順で復旧します"
                                   Foreground="#AEB7CE" FontSize="13" Margin="0,3,0,0" />
                    </StackPanel>
                </StackPanel>
                <Border Grid.Column="1" Background="#252E45" CornerRadius="16" Padding="13,7" VerticalAlignment="Center">
                    <TextBlock Text=".NET 10  •  WPF" Foreground="#C7CDE0" FontSize="12" FontWeight="SemiBold" />
                </Border>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="32,26,32,30">
                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="対象項目" FontSize="19" FontWeight="Bold" Foreground="{StaticResource TextBrush}" />
                        <TextBlock Text="まず診断で状態を確認できます。修復を選んだ場合だけ変更を行います。"
                                   Foreground="{StaticResource MutedTextBrush}" FontSize="12.5" Margin="0,5,0,0" />
                    </StackPanel>
                    <Button x:Name="DiagnoseAllButton" Grid.Column="1" Style="{StaticResource PrimaryButton}"
                            Content="すべて診断" Click="DiagnoseAll_Click" Padding="22,10" />
                </Grid>

                <ItemsControl x:Name="ModuleItems" ItemsSource="{Binding Modules}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="500" MinHeight="180" Margin="0,0,18,18" Padding="22"
                                    Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1" CornerRadius="14">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Border Width="42" Height="42" Background="#EEF0FF" CornerRadius="10" Margin="0,0,13,0">
                                            <TextBlock Text="{Binding Initials}" Foreground="#4B57CF" FontWeight="Bold" FontSize="18"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <TextBlock Grid.Column="1" Text="{Binding DisplayName}" Foreground="{StaticResource TextBrush}"
                                                   FontSize="15.5" FontWeight="Bold" VerticalAlignment="Center" TextWrapping="Wrap" />
                                        <Border Grid.Column="2" Background="{Binding StatusBackground}" CornerRadius="12"
                                                Padding="10,5" Margin="10,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding StatusText}" Foreground="{Binding StatusForeground}"
                                                       FontSize="11.5" FontWeight="SemiBold" />
                                        </Border>
                                    </Grid>
                                    <TextBlock Grid.Row="1" Text="{Binding Description}" TextWrapping="Wrap"
                                               Foreground="{StaticResource MutedTextBrush}" FontSize="12.5"
                                               LineHeight="20" Margin="0,14,0,17" />
                                    <Grid Grid.Row="2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="12" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Button Content="診断する" Tag="{Binding}" IsEnabled="{Binding CanDiagnose}"
                                                Click="Diagnose_Click" Style="{StaticResource QuietButton}" />
                                        <Button Grid.Column="2" Content="ワンクリック修復" Tag="{Binding}" IsEnabled="{Binding CanRepair}"
                                                Click="Repair_Click" Style="{StaticResource PrimaryButton}" />
                                    </Grid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Border Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1" CornerRadius="14" Padding="0" Margin="0,2,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="260" />
                        </Grid.RowDefinitions>
                        <Grid Background="#FAFAFC" Margin="1" Height="55">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal" Margin="18,0" VerticalAlignment="Center">
                                <Ellipse x:Name="ActivityDot" Width="8" Height="8" Fill="#98A2B3" Margin="0,0,9,0" />
                                <TextBlock x:Name="LogTitle" Text="実行ログ" Foreground="{StaticResource TextBrush}"
                                           FontWeight="SemiBold" FontSize="13" />
                            </StackPanel>
                            <Button Grid.Column="1" Content="コピー" Click="CopyLog_Click" Margin="0,8,8,8"
                                    Padding="13,4" MinHeight="0" FontSize="11.5" Style="{StaticResource QuietButton}" />
                            <Button Grid.Column="2" Content="ログフォルダー" Click="OpenLogs_Click" Margin="0,8,10,8"
                                    Padding="13,4" MinHeight="0" FontSize="11.5" Style="{StaticResource QuietButton}" />
                        </Grid>
                        <TextBox x:Name="LogBox" Grid.Row="1" IsReadOnly="True" AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                 TextWrapping="NoWrap" FontFamily="Cascadia Mono, Consolas" FontSize="12"
                                 Foreground="#D0D5DD" Background="#111827" BorderThickness="0" Padding="18,15"
                                 Text="診断または修復を選ぶと、ここに進行状況が表示されます。" />
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2" Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" Padding="32,13">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="GlobalStatus" Text="準備しています…" Foreground="{StaticResource MutedTextBrush}" FontSize="12.5" />
                <TextBlock Grid.Column="1" Text="必要な修復だけ管理者権限を要求します" Foreground="#98A2B3" FontSize="11.5" />
            </Grid>
        </Border>
    </Grid>
</Window>
